    'shipped': { bg: '#e3f2fd', color: '#1565c0', label: 'Shipped' },
    'delivered': { bg: '#e8f5e9', color: '#2e7d32', label: 'Delivered' },
    'cancelled': { bg: '#ffebee', color: '#c62828', label: 'Cancelled' }
