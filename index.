function toggleSearchBar() {
  const wrap = document.getElementById('searchBarWrap');
  wrap.style.display = wrap.style.display === 'none' ? 'block' : 'none';
  if (wrap.style.display === 'block') setTimeout(() => document.getElementById('searchInput').focus(), 100);
  else { document.getElementById('searchInput').value = ''; currentFilter = 'all'; renderGrid(); }
}

function handleSearch(query) {
  const grid = document.getElementById('productGrid');
  const q = query.toLowerCase().trim();
  if (!q) { renderGrid(); return; }
  const filtered = products.filter(p =>
    p.name.toLowerCase().includes(q) ||
    (p.desc || '').toLowerCase().includes(q) ||
    (p.category || '').toLowerCase().includes(q) ||
    (p.colors || []).join(' ').toLowerCase().includes(q)
  );
  grid.innerHTML = filtered.length ? filtered.map((p, i) => {
    const stockClass = p.stock > 10 ? 'in' : p.stock > 0 ? 'low' : 'out';
    const stockText = p.stock > 10 ? 'In Stock' : p.stock > 0 ? 'Only ' + p.stock + ' left' : 'Sold Out';
    const imgs = (p.images && p.images.length) ? p.images : [p.image];
    return `<div class="product-card" onclick="showDetail('${p.id}')" style="animation:fadeUp 0.4s ease ${i * 0.08}s both"></div><div class="product-info"><h3 class="product-name">${p.name}</h3><p class="product-cat">${p.colors.map(c => '<span class="product-color-dot" style="background:' + colorHex(c) + '"></span>').join('')} ${p.category}</p><p class="product-price">${formatPrice(p.price)}</p><p class="product-desc-short">${p.desc || ''}</p><div class="product-badge-row"><span class="product-stock-badge ${stockClass}">${stockText}</span></div><button class="card-add-btn" onclick="quickAddToCart('${p.id}', event)"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 01-8 0"/></svg> Add to Cart</button></div></div>`;
  }).join('') : '<p style="grid-column:1/-1;text-align:center;padding:60px;color:var(--muted);">No products found.</p>';
}

