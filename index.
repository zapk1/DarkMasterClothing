// ===== PRODUCT CAROUSEL HELPERS =====
function carouselScroll(carouselId, direction, event) {
  if (event) { event.stopPropagation(); event.preventDefault(); }
  var carousel = document.getElementById(carouselId);
  if (!carousel) return;
  carousel.scrollBy({ left: direction * carousel.offsetWidth, behavior: 'smooth' });
}

function carouselGoTo(carouselId, index, event) {
  if (event) { event.stopPropagation(); event.preventDefault(); }
  var carousel = document.getElementById(carouselId);
  if (!carousel) return;
  var imgs = carousel.querySelectorAll('img');
  if (imgs[index]) {
    imgs[index].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
  }
}

function updateCarouselDots(carouselId) {
  var carousel = document.getElementById(carouselId);
  var dotsWrap = document.getElementById('dots-' + carouselId);
  if (!carousel || !dotsWrap) return;
  var imgs = carousel.querySelectorAll('img');
  var dots = dotsWrap.querySelectorAll('.product-carousel-dot');
  if (!imgs.length || !dots.length) return;
  var scrollLeft = carousel.scrollLeft;
  var cardWidth = carousel.offsetWidth;
  var activeIndex = Math.round(scrollLeft / cardWidth);
  if (activeIndex < 0) activeIndex = 0;
  if (activeIndex >= imgs.length) activeIndex = imgs.length - 1;
  dots.forEach(function(d, i) {
    if (i === activeIndex) d.classList.add('active');
    else d.classList.remove('active');
  });
}

