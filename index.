        <span style="display:inline-flex;align-items:center;gap:4px;"><svg width="14" height="14"><use href="#i-user"/></svg> <strong>${order.customerName}</strong></span>
        <span style="display:inline-flex;align-items:center;gap:4px;"><svg width="14" height="14"><use href="#i-phone"/></svg> <strong>${order.customerPhone}</strong></span>
      </div>
