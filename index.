// ===== QUICK ADD FROM CARD =====
function quickAddToCart(id, event) {
  if (event) { event.stopPropagation(); event.preventDefault(); }
  const p = products.find(x => x.id === id);
  if (!p) return;
  if (!p.sizes || !p.sizes.length) { showToast('No sizes available', false); return; }
  addToCart(p, p.sizes[0], (p.colors && p.colors[0]) || 'Default', 1);
}

// ===== CART =====
function addToCart(product, size, color, qty) {
  const existing = cart.find(i => i.id === product.id && i.size === size && i.color === color);
  if (existing) {
    existing.qty += qty;
  } else {
    cart.push({ id: product.id, name: product.name, price: product.price, image: product.image, size, color, qty });
  }
  updateCart();
  showToast('Added to cart');
  openCart();
}

function removeFromCart(id, size, color) {
  cart = cart.filter(i => !(i.id === id && i.size === size && i.color === color));
  updateCart();
}

function changeCartQty(id, size, color, delta) {
  const item = cart.find(i => i.id === id && i.size === size && i.color === color);
  if (!item) return;
  item.qty = Math.max(1, item.qty + delta);
  updateCart();
}

function updateCart() {
  const count = cart.reduce((s, i) => s + i.qty, 0);
  const countEl = document.getElementById('cartCount');
  countEl.textContent = count;
  countEl.classList.toggle('hidden', count === 0);

  const body = document.getElementById('cartBody');
  const footer = document.getElementById('cartFooter');

  if (cart.length === 0) {
    body.innerHTML = `
      <div class="cart-empty">
        <svg width="48" height="48" style="color:var(--muted)"><use href="#i-bag"/></svg>
        <p>Your cart is empty.<br>Start building your collection.</p>
        <button class="btn-outline" onclick="closeCart()">Continue Shopping</button>
      </div>`;
    footer.style.display = 'none';
    return;
  }

  body.innerHTML = cart.map(item => `
    <div class="cart-item">
      <img src="${item.image}" alt="${item.name}" onclick="openImageViewer('${item.image}')">
      <div class="cart-item-info">
        <p class="cart-item-name">${item.name}</p>
        <p class="cart-item-meta"><span class="product-color-dot" style="background:${colorHex(item.color)}"></span> ${item.color} â€¢ Size: ${item.size}</p>
        <p class="cart-item-price">${formatPrice(item.price)}</p>
        <div class="cart-item-bottom">
          <div class="cart-qty">
            <button onclick="changeCartQty('${item.id}', '${item.size}', '${item.color}', -1)"><svg width="14" height="14"><use href="#i-minus"/></svg></button>
            <span>${item.qty}</span>
            <button onclick="changeCartQty('${item.id}', '${item.size}', '${item.color}', 1)"><svg width="14" height="14"><use href="#i-plus"/></svg></button>
          </div>
          <button class="cart-remove" onclick="removeFromCart('${item.id}', '${item.size}', '${item.color}')">
            <svg width="14" height="14"><use href="#i-trash"/></svg> Remove
          </button>
        </div>
      </div>
    </div>
  `).join('');

const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
  // Flat single delivery fee — R70 covers the whole order, never duplicated per item or quantity
  const totalDelivery = cart.length > 0 ? 70 : 0;
  const total = subtotal + totalDelivery;

  footer.style.display = 'block';
  footer.innerHTML = `
    <div class="cart-row muted"><span>Subtotal</span><span>${formatPrice(subtotal)}</span></div>
    <div class="cart-row muted"><span>Delivery</span><span>${totalDelivery > 0 ? formatPrice(totalDelivery) : 'Free'}</span></div>
    <div class="cart-row total"><span>Total</span><span>${formatPrice(total)}</span></div>
    <button class="btn-checkout" onclick="proceedToCheckout()">Checkout</button>
  `;
}

function openCart() {
  document.getElementById('cartOverlay').classList.add('open');
  document.getElementById('cartDrawer').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeCart() {
  document.getElementById('cartOverlay').classList.remove('open');
  document.getElementById('cartDrawer').classList.remove('open');
  document.body.style.overflow = '';
}




function proceedToCheckout() {
  localStorage.setItem('darkmaster_checkout_cart', JSON.stringify(cart));
  const body = document.getElementById('cartBody');
  const footer = document.getElementById('cartFooter');
  body.innerHTML = `
    <div style="padding:0;background:#ffffff;border-radius:var(--radius);">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;">
        <svg width="22" height="22" viewBox="0 0 24 24" style="color:#FF6B00;flex-shrink:0;" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <h3 style="font-size:15px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;">Checkout</h3>
