function saveCheckoutState() {
  const state = {
    name: document.getElementById('checkoutName')?.value || '',
    phone: document.getElementById('checkoutPhone')?.value || '',
    email: document.getElementById('checkoutEmail')?.value || '',
    province: document.getElementById('checkoutProvince')?.value || '',
    city: document.getElementById('checkoutCity')?.value || '',
    village: document.getElementById('checkoutVillage')?.value || '',
    address: document.getElementById('checkoutAddress')?.value || '',
    confirmed: document.getElementById('depositConfirmed')?.checked || false
  };
  localStorage.setItem('darkmaster_checkout_state', JSON.stringify(state));
}

function restoreCheckoutFields() {
  const state = JSON.parse(localStorage.getItem('darkmaster_checkout_state') || '{}');
  if (state.name) document.getElementById('checkoutName').value = state.name;
  if (state.phone) document.getElementById('checkoutPhone').value = state.phone;
  if (state.email) document.getElementById('checkoutEmail').value = state.email;
  if (state.province) document.getElementById('checkoutProvince').value = state.province;
  if (state.city) document.getElementById('checkoutCity').value = state.city;
  if (state.village) document.getElementById('checkoutVillage').value = state.village;
  if (state.address) document.getElementById('checkoutAddress').value = state.address;
  if (state.confirmed) document.getElementById('depositConfirmed').checked = state.confirmed;
  if (paymentProof) {
    document.getElementById('confirmPayBtn').disabled = !state.confirmed;
  }
}

function restoreCheckoutState() {
  const savedCart = JSON.parse(localStorage.getItem('darkmaster_checkout_cart') || 'null');
  if (savedCart && savedCart.length > 0 && cart.length === 0) {
    cart = savedCart;
    updateCart();
    const state = JSON.parse(localStorage.getItem('darkmaster_checkout_state') || 'null');
    if (state && state.name) {
      setTimeout(() => { openCart(); proceedToCheckout(); }, 500);
    }
  }
}

async function handleProofUpload(e) {
  const file = e.target.files[0];
  if (!file) return;

  document.getElementById('proofPlaceholder').innerHTML = '<div style="width:100%;"><div style="display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:6px;"><span>Uploading to ImgBB...</span><span id="proofPct">0%</span></div><div style="width:100%;height:8px;background:var(--border);border-radius:4px;overflow:hidden;"><div id="proofBar" style="width:0%;height:100%;background:#FF6B00;border-radius:4px;transition:width 0.2s;"></div></div></div>';

  const imgUrl = await uploadImageToImgBB(file, function(pct) {
    const bar = document.getElementById('proofBar');
    const label = document.getElementById('proofPct');
    if (bar) bar.style.width = pct + '%';
    if (label) label.textContent = pct + '%';
  });
  if (!imgUrl) {
    showToast('Upload failed. Please try again with a clear screenshot.', false);
    document.getElementById('proofPlaceholder').innerHTML = '<svg width="32" height="32" style="color:var(--muted);margin-bottom:8px;" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg><p style="font-size:13px;color:var(--muted);font-weight:600;">Tap to screenshot / photo your deposit proof</p><p style="font-size:11px;color:#c62828;margin-top:4px;">No proof = no order.</p>';
    return;
  }

  paymentProof = imgUrl;
  saveCheckoutState();
  const upload = document.getElementById('proofUpload');
  upload.style.borderColor = '#2e7d32';
  upload.style.borderStyle = 'solid';
  document.getElementById('proofPlaceholder').innerHTML = '<img src="' + paymentProof + '" style="max-width:100%;max-height:140px;border-radius:10px;margin-top:8px;" alt="Proof"><p style="font-size:12px;color:#2e7d32;font-weight:600;margin-top:6px;">✓ Proof attached</p>';
  document.getElementById('confirmPayBtn').disabled = !document.getElementById('depositConfirmed').checked || !paymentProof;
}




async function submitOrder() {
  const name = document.getElementById('checkoutName').value.trim();
  const phone = document.getElementById('checkoutPhone').value.trim();
  const email = document.getElementById('checkoutEmail').value.trim();
  const province = document.getElementById('checkoutProvince').value;
  const city = document.getElementById('checkoutCity').value.trim();
  const village = document.getElementById('checkoutVillage').value.trim();
  const address = document.getElementById('checkoutAddress').value.trim();
  const confirmed = document.getElementById('depositConfirmed').checked;

  if (!name) { showToast('Please enter your name', false); return; }
  if (!phone) { showToast('Please enter your phone number', false); return; }
  if (!email) { showToast('Please enter your email', false); return; }
  if (!province) { showToast('Please select your province', false); return; }
  if (!city) { showToast('Please enter your city/town', false); return; }
  if (!village) { showToast('Please enter your village / suburb / local area', false); return; }
  if (!address) { showToast('Please enter your street address + landmark', false); return; }
  if (!paymentProof) { showToast('Attach your deposit proof screenshot first — no proof, no order!', false); return; }
  if (!confirmed) { showToast('Please confirm you made the deposit', false); return; }

const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
  // Flat single delivery fee — R70 covers the whole order, never duplicated
  const totalDelivery = cart.length > 0 ? 70 : 0;


  const orderData = {
    customerName: name,
    customerPhone: phone,
    customerEmail: email,
    country: 'South Africa',
    province: province,
    city: city,
    village: village,
    address: address,
    items: cart.map(i => ({ ...i })),
    total: subtotal + totalDelivery,
    paymentMethod: 'EFT',
    paymentProof: paymentProof,
    status: 'pending_verification',
    createdAt: new Date().toISOString()
  };

  const orderId = await submitOrderToFirestore(orderData);

  cart = [];
  paymentProof = null;
  localStorage.removeItem('darkmaster_checkout_cart');
  localStorage.removeItem('darkmaster_checkout_state');
  updateCart();
  loadOrders();

  document.getElementById('cartBody').innerHTML = `
    <div style="text-align:center;padding:32px 16px;">
      <svg width="56" height="56" style="color:#2e7d32;margin-bottom:16px;" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      <h3 style="font-size:20px;font-weight:700;margin-bottom:8px;">Order Submitted!</h3>
      <p style="font-size:14px;color:var(--muted);margin-bottom:24px;">Your order <strong>${orderId || 'DM-' + Date.now().toString().slice(-6)}</strong> is pending verification. We'll contact you at ${phone} / ${email} once payment is confirmed.</p>
      <button class="btn-outline" onclick="closeCart()">Continue Shopping</button>
    </div>
  `;
  showToast('Order sent to admin!');
}




