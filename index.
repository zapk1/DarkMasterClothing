function heroSlideNext() { heroSlideIndex = (heroSlideIndex + 1) % heroSlides.length; renderHeroSlides(); resetHeroTimer(); }
function heroSlidePrev() { heroSlideIndex = (heroSlideIndex - 1 + heroSlides.length) % heroSlides.length; renderHeroSlides(); resetHeroTimer(); }
function heroGoTo(i) { heroSlideIndex = i; renderHeroSlides(); resetHeroTimer(); }
function resetHeroTimer() { clearInterval(heroSlideTimer); heroSlideTimer = setInterval(heroSlideNext, 4000); }

