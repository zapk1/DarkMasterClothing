<title>Dark Master Clothing</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  :root {
    --bg: #ffffff;
    --surface: #f8f8f8;
    --text: #111111;
    --muted: #888888;
    --border: #e5e5e5;
    --accent: #111111;
    --accent-fg: #ffffff;
    --danger: #e53935;
    --radius: 16px;
    --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.6; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; color: inherit; }

  /* ===== NAVBAR ===== */
  .navbar { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
  .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; height: 64px;
    display: flex; align-items: center; justify-content: space-between; }
  .nav-links { display: flex; gap: 32px; }
  .nav-link { font-size: 13px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }
  .nav-link:hover { color: var(--muted); }
.logo-wrap { flex: 1; text-align: center; cursor: pointer; pointer-events: auto; }
  .logo-main { display: flex; align-items: center; gap: 8px; justify-content: center; flex-direction: row; flex-wrap: nowrap; }
  .logo-text { font-size: 18px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; white-space: nowrap; }
  .sa-flag-icon { width: 16px !important; height: 11px !important; border-radius: 2px; object-fit: cover; flex-shrink: 0; }
  .sa-flag { font-size: 14px; }
  .logo-sub { font-size: 10px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--muted); margin-top: 6px; }
    .nav-left { flex: 1; display: flex; align-items: center; gap: 12px; }
  .nav-actions { flex: 1; display: flex; gap: 12px; align-items: center; justify-content: flex-end; }
    .icon-btn { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;
    border-radius: 50%; transition: all 0.2s; position: relative; }
  .icon-btn:hover { background: var(--surface); }
  .cart-count { position: absolute; top: 2px; right: 2px; background: var(--accent); color: var(--accent-fg);
    font-size: 10px; font-weight: 700; min-width: 18px; height: 18px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center; padding: 0 4px; }
  .cart-count.hidden { display: none; }
  .mobile-menu-btn { display: none; }

  /* ===== HERO ===== */
  .hero { text-align: center; padding: 80px 24px 60px; border-bottom: 1px solid var(--border); }
  .hero h1 { font-size: 48px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 16px; }
  .hero p { font-size: 17px; color: var(--muted); max-width: 520px; margin: 0 auto 32px; }
  .btn-primary { display: inline-block; padding: 14px 36px; background: var(--accent); color: var(--accent-fg);
    font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; border-radius: var(--radius);
    transition: opacity 0.2s; }
  .btn-primary:hover { opacity: 0.85; }
  .btn-outline { display: inline-block; padding: 14px 36px; background: transparent; color: var(--text);
    border: 1px solid var(--border); font-size: 13px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.1em; border-radius: var(--radius); transition: all 0.2s; }
  .btn-outline:hover { border-color: var(--text); }

  /* ===== PRODUCT GRID ===== */
  .section { max-width: 1200px; margin: 0 auto; padding: 60px 24px; }
  .section-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; }
  .section-title { font-size: 28px; font-weight: 700; letter-spacing: -0.01em; }
  .section-sub { font-size: 14px; color: var(--muted); margin-top: 4px; }
  .filter-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; }
  .filter-chip { padding: 8px 18px; border: 1px solid var(--border); border-radius: 50px; font-size: 12px;
    font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; transition: all 0.2s; }
  .filter-chip.active, .filter-chip:hover { background: var(--accent); color: var(--accent-fg); border-color: var(--accent); }
  .product-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .product-card { cursor: pointer; background: #fff; border: 1px solid var(--border);
    border-radius: var(--radius); overflow: hidden; transition: box-shadow 0.3s, transform 0.3s; }
  .product-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .product-img-wrap { position: relative; overflow: hidden; background: var(--surface); aspect-ratio: 3/4; }
  .product-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .product-card:hover .product-img-wrap img { transform: scale(1.05); }
  .badge-new { position: absolute; top: 12px; left: 12px; background: var(--bg); color: var(--text);
    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 5px 12px; border-radius: 3px; }
  .quick-add { position: absolute; bottom: 0; left: 0; right: 0; background: var(--accent); color: var(--accent-fg);
    padding: 14px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
    text-align: center; transform: translateY(100%); transition: transform 0.3s ease; }
  .product-card:hover .quick-add { transform: translateY(0); }
  .product-info { padding: 16px; }
  .product-name { font-size: 14px; font-weight: 600; line-height: 1.4; color: var(--text); }
  .product-cat { font-size: 11px; color: var(--muted); text-transform: capitalize; margin-top: 4px; }
  .product-price { font-size: 18px; font-weight: 800; color: #111; margin-top: 8px; }
  .product-desc-short { font-size: 12px; color: var(--muted); margin-top: 4px; line-height: 1.4;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .product-color-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; border: 1px solid var(--border); vertical-align: middle; margin-right: 4px; }
  .product-badge-row { display: flex; gap: 6px; margin-top: 8px; }
  .product-stock-badge { font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 3px; }
  .product-stock-badge.in { background: #e8f5e9; color: #2e7d32; }
  .product-stock-badge.low { background: #fff3e0; color: #f57c00; }
  .product-stock-badge.out { background: #ffebee; color: #c62828; }

  /* ===== PRODUCT DETAIL ===== */
  .detail-view { display: none; }
  .detail-view.active { display: block; }
  .breadcrumb { max-width: 1200px; margin: 0 auto; padding: 24px 24px 0; font-size: 13px; color: var(--muted); }
  .breadcrumb a:hover { color: var(--text); }
  .detail-grid { max-width: 1200px; margin: 0 auto; padding: 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
  .detail-img { background: var(--surface); border-radius: var(--radius); overflow: hidden; aspect-ratio: 3/4; }
  .detail-img img { width: 100%; height: 100%; object-fit: cover; }
  .detail-thumbs { display: flex; gap: 12px; margin-top: 12px; }
  .detail-thumb { width: 72px; height: 90px; background: var(--surface); border-radius: var(--radius); overflow: hidden;
    border: 2px solid transparent; cursor: pointer; transition: border-color 0.2s; }
  .detail-thumb.active { border-color: var(--accent); }
  .detail-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .detail-info h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
  .detail-price { font-size: 22px; font-weight: 600; margin-bottom: 24px; }
  .detail-desc { font-size: 15px; color: var(--muted); margin-bottom: 32px; line-height: 1.7; }
  .label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; }
  .size-options { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }
  .size-btn { min-width: 48px; height: 48px; border: 1px solid var(--border); border-radius: var(--radius);
    font-size: 14px; font-weight: 500; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
  .size-btn:hover { border-color: var(--text); }
  .size-btn.active { background: var(--accent); color: var(--accent-fg); border-color: var(--accent); }
  .qty-row { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; }
  .qty-control { display: flex; align-items: center; border: 1px solid var(--border); border-radius: var(--radius); }
  .qty-btn { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
  .qty-btn:hover { background: var(--surface); }
  .qty-val { width: 44px; text-align: center; font-size: 15px; font-weight: 500; }
  .btn-add-cart { width: 100%; padding: 16px; background: var(--accent); color: var(--accent-fg);
    font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; border-radius: var(--radius);
    display: flex; align-items: center; justify-content: center; gap: 10px; transition: opacity 0.2s; }
  .btn-add-cart:hover { opacity: 0.85; }
  .detail-features { margin-top: 40px; border-top: 1px solid var(--border); padding-top: 32px; }
  .feature-item { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; }
  .feature-icon { flex-shrink: 0; width: 20px; height: 20px; color: var(--muted); margin-top: 2px; }
  .feature-text { font-size: 14px; }
  .feature-text strong { display: block; font-weight: 600; }
  .feature-text span { color: var(--muted); font-size: 13px; }

  /* ===== CART DRAWER ===== */
  .cart-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200;
    opacity: 0; pointer-events: none; transition: opacity 0.3s; }
  .cart-overlay.open { opacity: 1; pointer-events: all; }
  .cart-drawer { position: fixed; top: 0; right: 0; bottom: 0; width: 100%; max-width: 420px;
    background: var(--bg); z-index: 210; transform: translateX(100%); transition: transform 0.3s ease;
    display: flex; flex-direction: column; }
  .cart-drawer.open { transform: translateX(0); }
  .cart-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px;
    border-bottom: 1px solid var(--border); }
  .cart-header h2 { font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
    display: flex; align-items: center; gap: 8px; }
  .cart-body { flex: 1; overflow-y: auto; padding: 20px 24px; }
  .cart-empty { display: flex; flex-direction: column; align-items: center; justify-content: center;
    height: 100%; text-align: center; color: var(--muted); }
  .cart-empty svg { margin-bottom: 16px; }
  .cart-empty p { font-size: 14px; margin-bottom: 24px; }
  .cart-item { display: flex; gap: 16px; padding: 16px 0; border-bottom: 1px solid var(--border); }
  .cart-item img { width: 72px; height: 90px; object-fit: cover; background: var(--surface); border-radius: var(--radius); }
  .cart-item-info { flex: 1; }
  .cart-item-name { font-size: 14px; font-weight: 500; }
  .cart-item-meta { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .cart-item-price { font-size: 14px; font-weight: 600; margin-top: 6px; }
  .cart-item-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 10px; }
  .cart-qty { display: flex; align-items: center; border: 1px solid var(--border); border-radius: var(--radius); }
  .cart-qty button { width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; }
  .cart-qty button:hover { background: var(--surface); }
  .cart-qty span { width: 30px; text-align: center; font-size: 13px; }
  .cart-remove { font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 4px; }
  .cart-remove:hover { color: var(--danger); }
  .cart-footer { border-top: 1px solid var(--border); padding: 20px 24px; }
  .cart-row { display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 8px; }
  .cart-row.muted { color: var(--muted); }
  .cart-row.total { font-size: 16px; font-weight: 700; padding-top: 12px; border-top: 1px solid var(--border); margin-top: 12px; }
  .btn-checkout { width: 100%; padding: 16px; background: var(--accent); color: var(--accent-fg);
    font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; border-radius: var(--radius);
    margin-top: 16px; transition: opacity 0.2s; }
  .btn-checkout:hover { opacity: 0.85; }

  /* ===== FEATURES STRIP ===== */
  .features-strip { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .features-inner { max-width: 1200px; margin: 0 auto; padding: 40px 24px; display: grid;
    grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .feature-strip-item { display: flex; align-items: flex-start; gap: 14px; }
  .feature-strip-item svg { flex-shrink: 0; width: 22px; height: 22px; color: var(--text); }
  .feature-strip-item h4 { font-size: 13px; font-weight: 600; }
  .feature-strip-item p { font-size: 12px; color: var(--muted); margin-top: 2px; }

  /* ===== FOOTER ===== */
  .footer { border-top: 1px solid var(--border); margin-top: 40px; }
  .footer-inner { max-width: 1200px; margin: 0 auto; padding: 60px 24px 32px; display: grid;
    grid-template-columns: 2fr 1fr 1fr; gap: 48px; }
  .footer-brand h3 { font-size: 18px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 16px; }
  .footer-brand p { font-size: 14px; color: var(--muted); max-width: 320px; margin-bottom: 24px; }
  .social-row { display: flex; gap: 12px; }
  .social-btn { width: 40px; height: 40px; border: 1px solid var(--border); border-radius: 50%;
    display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
  .social-btn:hover { background: var(--accent); color: var(--accent-fg); border-color: var(--accent); }
  .footer-col h4 { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 16px; color: var(--muted); }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 10px; }
  .footer-col a { font-size: 14px; }
  .footer-col a:hover { color: var(--muted); }
  .footer-bottom { max-width: 1200px; margin: 0 auto; padding: 24px; border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: var(--muted); }
  .footer-bottom-links { display: flex; gap: 24px; }

  /* ===== TOAST ===== */
    .toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(100px);
    background: #FF6B00; color: #ffffff; padding: 14px 28px; border-radius: var(--radius);
    font-size: 14px; font-weight: 500; z-index: 300; opacity: 0; transition: all 0.3s ease;
    display: flex; align-items: center; gap: 10px; }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* ===== BACK BUTTON ===== */
  .back-btn { position: fixed; top: 80px; left: 16px; z-index: 90; display: none;
    align-items: center; gap: 6px; padding: 10px 18px; background: #e53935; color: #fff;
    border-radius: 50px; font-size: 13px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; box-shadow: 0 2px 12px rgba(229,57,53,0.3);
    transition: opacity 0.2s; }
  .back-btn:hover { opacity: 0.9; }
  .back-btn.visible { display: flex; }

  /* ===== SCROLL TO TOP ===== */
  .scroll-top-btn { position: fixed; bottom: 24px; right: 24px; z-index: 90;
    width: 48px; height: 48px; background: var(--accent); color: var(--accent-fg);
    border-radius: 50%; display: none; align-items: center; justify-content: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.2); transition: all 0.2s; }
  .scroll-top-btn:hover { transform: scale(1.1); }
  .scroll-top-btn.visible { display: flex; }
  .scroll-top-btn svg { transform: rotate(-90deg); }

/* ===== ADMIN OVERLAY ===== */
    #adminOverlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 300;
    opacity: 0; pointer-events: none; transition: opacity 0.3s; }
  #adminOverlay.open { opacity: 1; pointer-events: all; }
  #adminModal { position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    width: 100%; max-width: none; max-height: none; height: 100vh; background: var(--bg);
    border-radius: 0; z-index: 310; display: none; flex-direction: column;
    overflow: hidden; box-shadow: none; }
  #adminModal.open { display: flex !important; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
    .features-inner { grid-template-columns: repeat(2, 1fr); }
    .detail-grid { grid-template-columns: 1fr; gap: 32px; }
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 600px) {
    .nav-links { display: none; }
    .mobile-menu-btn { display: flex; }
    .logo-text { font-size: 14px; }
    .logo-sub { font-size: 9px; }
    .sa-flag { font-size: 12px; }
    .nav-actions .icon-btn[aria-label="Search"],
    .nav-actions .icon-btn[aria-label="Account"] { display: none; }
    .hero h1 { font-size: 34px; }
    .section { padding: 40px 16px; }
    .product-grid { grid-template-columns: 1fr; gap: 24px; }
    .features-inner { grid-template-columns: 1fr; }
    .section-header { flex-direction: column; align-items: flex-start; gap: 12px; }
    .detail-grid { padding: 16px; }
    .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
</head>
