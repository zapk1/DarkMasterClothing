async function deleteProduct(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  if (!confirm('Delete "' + p.name + '"? This cannot be undone.')) return;
  try {
    await db.collection(PRODUCTS_COLLECTION).doc(id).delete();
    showToast('Product deleted!');
    loadProducts();
    showAdminProducts();
  } catch (err) {
    showToast('Error deleting product', false);
  }
}

async function handleProductImageUpload(e) {
  const files = Array.from(e.target.files);
  if (!files.length) return;
  const label = e.target.closest('label');
  e.target.value = '';
  const preview = document.getElementById('productImgPreview');
  for (let fi = 0; fi < files.length; fi++) {
    const file = files[fi];
    const slotId = 'prod-up-' + Date.now() + '-' + fi;
    
    
    if (preview) preview.insertAdjacentHTML('beforeend',
      '<div id="' + slotId + '" style="position:relative;width:72px;height:72px;border:2px solid #FF6B00;border-radius:10px;overflow:hidden;background:#fff8f3;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px;">' +
        '<div style="width:100%;height:10px;background:#eee;border-radius:5px;overflow:hidden;margin-bottom:6px;">' +
          '<div class="bar" style="width:0%;height:100%;background:#FF6B00;border-radius:5px;transition:width 0.1s linear;"></div>' +
        '</div>' +
        '<span class="pct" style="font-size:11px;color:#FF6B00;font-weight:700;">0%</span>' +
      '</div>');
    const labelEl = e.target.closest('label');
    if (labelEl) labelEl.querySelector('p').textContent = 'Uploading ' + (fi+1) + ' of ' + files.length + '...';
    const url = await uploadImageToImgBB(file, function(pct) {
      const slot = document.getElementById(slotId);
      if (slot) {
        slot.querySelector('.bar').style.width = pct + '%';
        slot.querySelector('.pct').textContent = pct + '%';
      }
    });
    
    
    const slot = document.getElementById(slotId);
    if (url) {
      newProductImageUrls.push(url);
      if (slot) {
        slot.innerHTML = '<img src="' + url + '" style="width:100%;height:100%;object-fit:cover;">';
        slot.style.border = '2px solid #2e7d32';
        slot.style.padding = '0';
      }
    } else {
      if (slot) {
        slot.innerHTML = '<span style="font-size:9px;color:#c62828;text-align:center;font-weight:600;">Failed</span>';
        slot.style.borderColor = '#c62828';
      }
    }
  }
  newProductImageUrl = newProductImageUrls[0] || null;
  if (label) label.querySelector('p').textContent = newProductImageUrls.length === 0
    ? 'Upload product image(s) — ImgBB'
    : (newProductImageUrls.length + ' image(s) uploaded — click to add more');
  renderProductImgPreview();
}

function renderProductImgPreview() {
  const preview = document.getElementById('productImgPreview');
  if (!preview) return;
  preview.innerHTML = newProductImageUrls.map((u, i) => `
    <div style="position:relative;width:64px;height:64px;">
      <img src="${u}" style="width:64px;height:64px;object-fit:cover;border-radius:8px;border:2px solid ${i === 0 ? '#FF6B00' : 'var(--border)'};">
      ${i === 0 ? '<span style="position:absolute;bottom:-2px;left:50%;transform:translateX(-50%);font-size:8px;font-weight:700;background:#FF6B00;color:#fff;padding:1px 6px;border-radius:0 0 4px 4px;">MAIN</span>' : ''}
      <button type="button" onclick="removeProductImage(${i})" aria-label="Remove" style="position:absolute;top:-6px;right:-6px;width:22px;height:22px;background:#e53935;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,0,0,0.3);">
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  `).join('');
}

function removeProductImage(index) {
  newProductImageUrls.splice(index, 1);
  newProductImageUrl = newProductImageUrls[0] || null;
  renderProductImgPreview();
}

async function saveNewProduct() {
  const name = document.getElementById('newProductName').value.trim();
  const desc = document.getElementById('newProductDesc').value.trim();
  const price = parseInt(document.getElementById('newProductPrice').value);
  const stock = parseInt(document.getElementById('newProductStock').value);
  const sizes = document.getElementById('newProductSizes').value.split(',').map(s => s.trim()).filter(Boolean);
  const colors = document.getElementById('newProductColors').value.split(',').map(s => s.trim()).filter(Boolean);
  const materials = document.getElementById('newProductMaterials').value.trim();
  const fit = document.getElementById('newProductFit').value.trim();
  const deliveryType = 'charged';
  const deliveryFee = parseInt(document.getElementById('newProductDeliveryFee').value) || 70;





if (!name) { showToast('Enter product name', false); return; }
  if (!price || isNaN(price)) { showToast('Enter a valid price', false); return; }
  if (newProductImageUrls.length === 0) { showToast('Upload at least one image', false); return; }
  const location = document.getElementById('newProductLocation').value.trim() || 'South Africa';

  const productData = {
    name, desc, price,
    stock: stock || 0,
    sizes, colors, materials, fit,
    deliveryType: 'charged',
    deliveryFee,
    image: newProductImageUrls[0],
    images: newProductImageUrls,
    category: 'tops',
    isNew: true,
    location
  };

  const saveBtn = document.querySelector('#addProductForm .btn-checkout');
  if (saveBtn) { saveBtn.disabled = true; saveBtn.textContent = 'Saving…'; }

  try {
    if (editingProductId) {
      await db.collection(PRODUCTS_COLLECTION).doc(editingProductId).update(productData);
      showToast('Product updated!');
    } else {
      await db.collection(PRODUCTS_COLLECTION).add(productData);
      showToast('Product saved!');
    }
    editingProductId = null;
    newProductImageUrl = null;
    newProductImageUrls = [];
    loadProducts();
    showAdminProducts();
  } catch (err) {
    console.error('Save error:', err);
    showToast('Error: ' + err.message, false);
    if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'Save Product'; }
  }
}



